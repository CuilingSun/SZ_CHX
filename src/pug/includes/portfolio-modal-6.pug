// Portfolio item 6 modal popup
#portfolioModal6.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase(data-i18n='modal6.title', data-en='Shipbuilding & Maintenance Manufacturing', data-zh='船舶及维修制造') Shipbuilding & Maintenance Manufacturing
                            p.item-intro.text-muted(data-i18n='modal6.intro', data-en='Heavy-duty sealing support for marine systems, repair workshops, and ship component manufacturing.' data-zh='适用于船舶系统、维修车间和船舶部件制造的重载密封支持。') Heavy-duty sealing support for marine systems, repair workshops, and ship component manufacturing.
                            img.img-fluid.d-block.mx-auto(src='assets/img/industry/船舶.jpg', alt='...')
                            p(data-i18n='modal6.text', data-en='Shipbuilding and maintenance manufacturing demand materials that tolerate salt mist, heavy loads, and harsh operational environments. Our products can support hatch systems, pumps, pipelines, and maintenance assemblies in marine applications.' data-zh='船舶及维修制造场景通常面临盐雾、重载和复杂环境等挑战。我们的产品可应用于舱口系统、泵阀管路以及船舶维修装配环节，满足海事领域对可靠性的要求。') Shipbuilding and maintenance manufacturing demand materials that tolerate salt mist, heavy loads, and harsh operational environments. Our products can support hatch systems, pumps, pipelines, and maintenance assemblies in marine applications.
                            ul.list-inline
                                li
                                    strong(data-i18n='modal.industry', data-en='Industry:' data-zh='行业：') Industry:
                                    | Shipbuilding & Maintenance Manufacturing
                                li
                                    strong(data-i18n='modal.application', data-en='Application:' data-zh='应用：') Application:
                                    span(data-i18n='modal6.category', data-en='Marine Systems', data-zh='船舶系统') Marine Systems
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                span(data-i18n='modal.close', data-en='Close' data-zh='关闭') Close
