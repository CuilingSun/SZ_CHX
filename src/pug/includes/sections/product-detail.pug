section.page-section.product-detail-section
    -
        const galleryImages = typeof productImages !== 'undefined' && productImages && productImages.length
            ? productImages
            : [{ src: productImage, altEn: productNameEn, altZh: productNameZh }]
        const galleryAutoMs = typeof productGalleryAutoMs !== 'undefined' ? productGalleryAutoMs : 2200
        const galleryThemeClass = typeof productGalleryTheme !== 'undefined' && productGalleryTheme
            ? `product-detail-media-${productGalleryTheme}`
            : ''
        const hasProductPdf = typeof productPdf !== 'undefined' && productPdf
    .container
        a.product-back-link(href='products.html', data-product-back-link='true')
            span.product-back-icon(aria-hidden='true') ←
            span(data-i18n='productDetail.back', data-en='Back to Product Center', data-zh='返回产品中心') Back to Product Center
        .row.g-5.align-items-start
            .col-lg-5
                .product-detail-media(class=galleryThemeClass, data-product-gallery='true', data-gallery-interval=galleryAutoMs)
                    .product-detail-gallery-track(data-product-gallery-track='true')
                        each image, imageIndex in galleryImages
                            .product-detail-gallery-slide(class=imageIndex === 0 ? 'is-active' : '', data-product-gallery-slide='true')
                                img.img-fluid(
                                    src=image.src,
                                    alt=image.altEn,
                                    data-i18n=`productDetail.gallery.${imageIndex + 1}.alt`,
                                    data-en=image.altEn,
                                    data-zh=image.altZh
                                )
                    if galleryImages.length > 1
                        button.product-detail-gallery-control.product-detail-gallery-control-prev(type='button', aria-label='Previous image', data-product-gallery-prev='true')
                            svg.product-detail-gallery-icon(viewBox='0 0 24 24', aria-hidden='true', focusable='false')
                                path(d='M15 5L8 12L15 19')
                        button.product-detail-gallery-control.product-detail-gallery-control-next(type='button', aria-label='Next image', data-product-gallery-next='true')
                            svg.product-detail-gallery-icon(viewBox='0 0 24 24', aria-hidden='true', focusable='false')
                                path(d='M9 5L16 12L9 19')
                        .product-detail-gallery-indicators
                            each image, imageIndex in galleryImages
                                button.product-detail-gallery-indicator(
                                    type='button',
                                    class=imageIndex === 0 ? 'is-active' : '',
                                    aria-label=`Go to image ${imageIndex + 1}`,
                                    data-product-gallery-indicator='true',
                                    data-gallery-index=imageIndex
                                )
            .col-lg-7
                .product-detail-panel
                    p.product-detail-kicker(data-i18n='productDetail.label', data-en='Industrial Product' data-zh='工业产品') Industrial Product
                    h2.product-detail-title(data-i18n='productDetail.title', data-en=productNameEn, data-zh=productNameZh)= productNameEn
                    p.product-detail-lead(data-i18n='productDetail.lead', data-en=productLeadEn, data-zh=productLeadZh)= productLeadEn
                    p.product-detail-description(data-i18n='productDetail.description', data-en=productDescriptionEn, data-zh=productDescriptionZh)= productDescriptionEn
                    .product-detail-feature-grid
                        .product-detail-feature
                            h3(data-i18n='productDetail.feature1.title', data-en=featureTitle1En, data-zh=featureTitle1Zh)= featureTitle1En
                            p(data-i18n='productDetail.feature1.text', data-en=featureText1En, data-zh=featureText1Zh)= featureText1En
                        .product-detail-feature
                            h3(data-i18n='productDetail.feature2.title', data-en=featureTitle2En, data-zh=featureTitle2Zh)= featureTitle2En
                            p(data-i18n='productDetail.feature2.text', data-en=featureText2En, data-zh=featureText2Zh)= featureText2En
                        .product-detail-feature
                            h3(data-i18n='productDetail.feature3.title', data-en=featureTitle3En, data-zh=featureTitle3Zh)= featureTitle3En
                            p(data-i18n='productDetail.feature3.text', data-en=featureText3En, data-zh=featureText3Zh)= featureText3En
                    if hasProductPdf
                        .product-detail-actions
                            button.product-detail-spec-link(
                                type='button',
                                data-product-pdf-trigger='true',
                                data-product-pdf-src=`${productPdf}#view=FitH`
                            )
                                svg.product-detail-spec-link-icon(viewBox='0 0 24 24', aria-hidden='true', focusable='false')
                                    path(d='M7 3h7l5 5v13H7z')
                                    path(d='M14 3v6h5')
                                span(data-i18n='productDetail.specButton', data-en='View Specification PDF', data-zh='查看规格书 PDF') View Specification PDF
    if hasProductPdf
        .product-pdf-modal(hidden data-product-pdf-modal='true' aria-hidden='true')
            .product-pdf-modal-backdrop(data-product-pdf-close='true')
            .product-pdf-modal-dialog(role='dialog' aria-modal='true' aria-labelledby='productPdfModalTitle')
                .product-pdf-modal-header
                    h3#productPdfModalTitle.product-pdf-modal-title(data-i18n='productDetail.specModalTitle', data-en='Product Specification', data-zh='产品规格预览') Product Specification
                    button.product-pdf-modal-close(type='button', aria-label='Close specification preview', data-product-pdf-close='true')
                        span(aria-hidden='true') ×
                .product-pdf-modal-body
                    iframe.product-pdf-modal-frame(
                        src=productPdf,
                        title=productNameEn,
                        loading='lazy'
                    )
