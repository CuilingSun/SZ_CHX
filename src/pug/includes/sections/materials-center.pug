section.materials-page
    .container
        section.materials-jump-panel.page-section
            .materials-jump-links
                a.materials-jump-link(href='#materialsCompare', data-i18n='materials.jump.compare', data-en='Quick Comparison', data-zh='快速对比') Quick Comparison
                a.materials-jump-link(href='#materialsDetail', data-i18n='materials.jump.detail', data-en='Material Details', data-zh='材料详情') Material Details
                a.materials-jump-link(href='#materialsScenes', data-i18n='materials.jump.scenes', data-en='Condition Guide', data-zh='工况推荐') Condition Guide

        section#materialsCompare.materials-compare-panel.page-section
            .materials-section-heading
                p.materials-kicker(data-i18n='materials.compare.kicker', data-en='Quick Comparison', data-zh='快速对比') Quick Comparison
                h2(data-i18n='materials.compare.title', data-en='Material Comparison Matrix', data-zh='材料快速对比') Material Comparison Matrix
                p(data-i18n='materials.compare.text', data-en='Compare key material properties at a glance to shorten evaluation time for engineering and purchasing teams.' data-zh='通过一张对比表快速理解关键材料差异，帮助采购和工程团队更高效地完成初步选材。') Compare key material properties at a glance to shorten evaluation time for engineering and purchasing teams.
            .materials-table-wrap
                table.materials-table
                    thead
                        tr
                            th(data-i18n='materials.compare.material', data-en='Material', data-zh='材料') Material
                            each column in compareColumns
                                if column.key === 'chemical'
                                    th.materials-th-chemical
                                        span.materials-th-chemical-en Chemical
                                        span.materials-th-chemical-en Resistance
                                        span.materials-th-chemical-zh 耐腐蚀性
                                else if column.key === 'wear'
                                    th.materials-th-wear
                                        span.materials-th-wear-en Wear
                                        span.materials-th-wear-en Resistance
                                        span.materials-th-wear-zh 耐磨性
                                else
                                    th(data-i18n=`materials.compare.columns.${column.key}`, data-en=column.labelEn, data-zh=column.labelZh)= column.labelEn
                    tbody
                        each item in materialsCompare
                            tr
                                th(scope='row')
                                    .materials-table-material
                                        strong= item.nameEn
                                        span.materials-name-zh(data-i18n=`materials.compare.${item.key}.nameZh`, data-en=item.nameZh, data-zh=item.nameZh)= item.nameZh
                                td
                                    span(class=`materials-pill ${item.oilClass}`, data-i18n=`materials.compare.${item.key}.oil`, data-en=item.oilEn, data-zh=item.oilZh)= item.oilEn
                                td
                                    .materials-temp
                                        strong(data-i18n=`materials.compare.${item.key}.temp`, data-en=item.tempEn, data-zh=item.tempZh)= item.tempEn
                                td
                                    span(class=`materials-pill ${item.chemicalClass}`, data-i18n=`materials.compare.${item.key}.chemical`, data-en=item.chemicalEn, data-zh=item.chemicalZh)= item.chemicalEn
                                td
                                    span(class=`materials-pill ${item.wearClass}`, data-i18n=`materials.compare.${item.key}.wear`, data-en=item.wearEn, data-zh=item.wearZh)= item.wearEn
                                td
                                    span(class=`materials-pill cost-${item.costClass}`, data-i18n=`materials.compare.${item.key}.cost`, data-en=item.costEn, data-zh=item.costZh)= item.costEn
                                td(data-i18n=`materials.compare.${item.key}.typical`, data-en=item.typicalEn, data-zh=item.typicalZh)= item.typicalEn

        section#materialsDetail.materials-detail-panel.page-section
            .materials-section-heading
                p.materials-kicker(data-i18n='materials.detail.kicker', data-en='Material Profiles', data-zh='材料说明') Material Profiles
                h2(data-i18n='materials.detail.title', data-en='Detailed Material Cards', data-zh='材料详情卡片') Detailed Material Cards
                p(data-i18n='materials.detail.text', data-en='Review properties, product fit, and industry recommendations for each major sealing compound.' data-zh='进一步查看每种材料的特点、推荐产品和适用行业，帮助您做更精准的选材判断。') Review properties, product fit, and industry recommendations for each major sealing compound.
            .materials-card-grid
                each item in materialCards
                    article.material-card
                        .material-card-head
                            p.material-card-label(data-i18n='materials.detail.label', data-en='Material', data-zh='材料') Material
                            h3= item.nameEn
                            p.material-card-zh(data-i18n=`materials.detail.${item.key}.zhName`, data-en=item.nameZh, data-zh=item.nameZh)= item.nameZh
                        p.material-card-intro(data-i18n=`materials.detail.${item.key}.intro`, data-en=item.introEn, data-zh=item.introZh)= item.introEn
                        .material-card-meta
                            .material-meta-block
                                h4(data-i18n='materials.detail.features', data-en='Key Features', data-zh='主要特点') Key Features
                                ul
                                    each feature, index in item.featuresEn
                                        li(data-i18n=`materials.detail.${item.key}.features.${index}`, data-en=item.featuresEn[index], data-zh=item.featuresZh[index])= feature
                            .material-meta-block.material-meta-temp
                                h4(data-i18n='materials.detail.tempRange', data-en='Temperature Range', data-zh='温度范围') Temperature Range
                                p(data-i18n=`materials.detail.${item.key}.temp`, data-en=item.tempEn, data-zh=item.tempZh)= item.tempEn
                        .material-meta-block
                            h4(data-i18n='materials.detail.products', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                            .material-tag-row
                                each product, index in item.products
                                    if product.href
                                        a.material-tag.material-tag-link(href=product.href, data-i18n=`materials.detail.${item.key}.products.${index}`, data-en=product.en, data-zh=product.zh)= product.en
                                    else
                                        span.material-tag(data-i18n=`materials.detail.${item.key}.products.${index}`, data-en=product.en, data-zh=product.zh)= product.en
                        .material-meta-block
                            h4(data-i18n='materials.detail.industries', data-en='Industries / Typical Scenarios', data-zh='适用行业 / 典型场景') Industries / Typical Scenarios
                            .material-tag-row
                                each industry, index in item.industriesEn
                                    span.material-tag.muted(data-i18n=`materials.detail.${item.key}.industries.${index}`, data-en=item.industriesEn[index], data-zh=item.industriesZh[index])= industry

        section#materialsScenes.materials-scenes-panel.page-section
            .materials-section-heading
                p.materials-kicker(data-i18n='materials.scene.kicker', data-en='Working Condition Guide', data-zh='工况推荐') Working Condition Guide
                h2(data-i18n='materials.scene.title', data-en='Select Materials by Operating Condition', data-zh='根据工况选材料') Select Materials by Operating Condition
                p(data-i18n='materials.scene.text', data-en='A quick decision aid for buyers and engineers who need to shortlist materials based on actual service conditions.' data-zh='面向采购和工程人员的快速判断模块，帮助您根据实际工况缩小选材范围。') A quick decision aid for buyers and engineers who need to shortlist materials based on actual service conditions.
            .materials-scene-grid
                each scene in workingConditions
                    article.material-scene-card
                        h3(data-i18n=`materials.scene.${scene.key}.title`, data-en=scene.titleEn, data-zh=scene.titleZh)= scene.titleEn
                        p.material-scene-materials(data-i18n=`materials.scene.${scene.key}.materials`, data-en=scene.materialsEn, data-zh=scene.materialsZh)= scene.materialsEn
                        p.material-scene-text(data-i18n=`materials.scene.${scene.key}.text`, data-en=scene.textEn, data-zh=scene.textZh)= scene.textEn

        section#materialsCta.materials-cta.page-section
            .materials-cta-panel
                p.materials-kicker(data-i18n='materials.cta.kicker', data-en='Need Help Selecting?' data-zh='选材支持') Need Help Selecting?
                h2(data-i18n='materials.cta.title', data-en='Can’t Find the Right Material?' data-zh='找不到合适材料？') Can’t Find the Right Material?
                p(data-i18n='materials.cta.text', data-en='We provide material selection advice, size matching, and custom support for demanding sealing applications.' data-zh='我们提供材料选型建议、规格匹配与定制支持，帮助您更快确定适合的密封解决方案。') We provide material selection advice, size matching, and custom support for demanding sealing applications.
                .materials-cta-actions
                    a.btn.btn-primary.btn-xl(href='contact.html', data-i18n='materials.cta.contact', data-en='Contact Us', data-zh='联系我们') Contact Us
                    a.btn.btn-outline-light.btn-xl(href='products.html', data-i18n='materials.cta.products', data-en='Back to Product Center', data-zh='返回产品中心') Back to Product Center
