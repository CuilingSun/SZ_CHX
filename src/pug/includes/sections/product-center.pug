section#productCenter.page-section.product-center
    .container
        .row.g-4.g-xl-5
            .col-lg-3
                aside.product-sidebar
                    p.product-sidebar-kicker(data-i18n='productCenter.kicker', data-en='Category Filter', data-zh='分类筛选') Category Filter
                    h2.product-sidebar-title(data-i18n='productCenter.title', data-en='Product Center', data-zh='产品中心') Product Center
                    p.product-sidebar-copy(data-i18n='productCenter.text', data-en='Browse categories and quickly locate the product family you need.' data-zh='通过左侧分类快速筛选，找到你需要的产品系列。') Browse categories and quickly locate the product family you need.
                    .product-filter-list(role='tablist', aria-label='Product categories')
                        button.product-filter-btn.active(type='button', data-product-filter='all', data-i18n='productCenter.filter.all', data-en='All Products', data-zh='全部产品') All Products
                        button.product-filter-btn(type='button', data-product-filter='o-rings', data-i18n='productCenter.filter.oRings', data-en='O-Rings', data-zh='O型圈') O-Rings
                        button.product-filter-btn(type='button', data-product-filter='v-rings', data-i18n='productCenter.filter.vRings', data-en='V-Rings', data-zh='V型圈') V-Rings
                        button.product-filter-btn(type='button', data-product-filter='x-rings', data-i18n='productCenter.filter.xRings', data-en='X-Rings', data-zh='X型圈') X-Rings
                        button.product-filter-btn(type='button', data-product-filter='y-rings', data-i18n='productCenter.filter.yRings', data-en='Y-Rings', data-zh='Y型圈') Y-Rings
                        button.product-filter-btn(type='button', data-product-filter='flat-washers', data-i18n='productCenter.filter.flatWashers', data-en='Flat Washers', data-zh='平垫圈') Flat Washers
                        button.product-filter-btn(type='button', data-product-filter='rubber-products', data-i18n='productCenter.filter.rubberProducts', data-en='Rubber Products', data-zh='橡胶制品') Rubber Products
            .col-lg-9
                .product-content-panel
                    .product-content-header
                        h3.product-content-heading(data-i18n='productCenter.gridTitle', data-en='Industrial Product Catalog', data-zh='工业产品目录') Industrial Product Catalog
                        p.product-content-copy(data-i18n='productCenter.gridText', data-en='Each product card links to an individual detail page for specifications, use cases, and product highlights.' data-zh='每个产品卡片都可进入独立详情页，查看规格、应用场景和产品亮点。') Each product card links to an individual detail page for specifications, use cases, and product highlights.
                    .product-grid
                        a.product-card(href='product-o-rings.html', data-product-category='o-rings')
                            .product-card-media
                                img(src='assets/img/portfolio/1.jpg', alt='O-Rings')
                            .product-card-body
                                p.product-card-category(data-i18n='productCenter.card1.category', data-en='Sealing Ring Series', data-zh='密封圈系列') Sealing Ring Series
                                h4.product-card-title(data-i18n='productCenter.card1.title', data-en='O-Rings', data-zh='O型圈') O-Rings
                        a.product-card(href='product-v-rings.html', data-product-category='v-rings')
                            .product-card-media
                                img(src='assets/img/portfolio/2.jpg', alt='V-Rings')
                            .product-card-body
                                p.product-card-category(data-i18n='productCenter.card2.category', data-en='Rotary Sealing Series', data-zh='旋转密封系列') Rotary Sealing Series
                                h4.product-card-title(data-i18n='productCenter.card2.title', data-en='V-Rings', data-zh='V型圈') V-Rings
                        a.product-card(href='product-x-rings.html', data-product-category='x-rings')
                            .product-card-media
                                img(src='assets/img/portfolio/3.jpg', alt='X-Rings')
                            .product-card-body
                                p.product-card-category(data-i18n='productCenter.card3.category', data-en='Dynamic Seal Series', data-zh='动态密封系列') Dynamic Seal Series
                                h4.product-card-title(data-i18n='productCenter.card3.title', data-en='X-Rings', data-zh='X型圈') X-Rings
                        a.product-card(href='product-y-rings.html', data-product-category='y-rings')
                            .product-card-media
                                img(src='assets/img/portfolio/4.jpg', alt='Y-Rings')
                            .product-card-body
                                p.product-card-category(data-i18n='productCenter.card4.category', data-en='Hydraulic Seal Series', data-zh='液压密封系列') Hydraulic Seal Series
                                h4.product-card-title(data-i18n='productCenter.card4.title', data-en='Y-Rings', data-zh='Y型圈') Y-Rings
                        a.product-card(href='product-flat-washers.html', data-product-category='flat-washers')
                            .product-card-media
                                img(src='assets/img/portfolio/5.jpg', alt='Flat Washers')
                            .product-card-body
                                p.product-card-category(data-i18n='productCenter.card5.category', data-en='Auxiliary Seal Series', data-zh='辅助密封系列') Auxiliary Seal Series
                                h4.product-card-title(data-i18n='productCenter.card5.title', data-en='Flat Washers', data-zh='平垫圈') Flat Washers
                        a.product-card(href='product-rubber-products.html', data-product-category='rubber-products')
                            .product-card-media
                                img(src='assets/img/portfolio/6.jpg', alt='Rubber Products')
                            .product-card-body
                                p.product-card-category(data-i18n='productCenter.card6.category', data-en='Custom Rubber Solutions', data-zh='定制橡胶方案') Custom Rubber Solutions
                                h4.product-card-title(data-i18n='productCenter.card6.title', data-en='Rubber Products', data-zh='橡胶制品') Rubber Products
