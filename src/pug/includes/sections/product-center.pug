section#productCenter.page-section.product-center
    .container
        .product-overview-panel
            .product-overview-copy
                p.product-overview-kicker
                    span.product-overview-kicker-zh 创鸿信产品体系
                    span.product-overview-kicker-en CHX Product System
                h2.product-overview-title
                    span.product-overview-title-zh 面向设备制造、液压系统、旋转密封与定制需求的工业密封产品体系
                    span.product-overview-title-en
                        | Industrial Sealing Products for Equipment,
                        br
                        | Hydraulic, Rotary, and Custom Applications
                p.product-overview-text
                    span.product-overview-text-zh 创鸿信提供密封圈、液压密封件、油封、工程密封件及相关工业配件，服务于设备制造、维修保养和备件替换等多类工业需求。
                    span.product-overview-text-en
                        | CHX supplies a broad range of sealing rings, hydraulic seals, oil seals,
                        br
                        | engineered sealing components, and related industrial parts for equipment manufacturing, maintenance, and replacement needs.

        .product-directory-layout
            aside.product-directory-sidebar
                p.product-directory-kicker(data-i18n='products.directory.kicker', data-en='Category Index', data-zh='分类索引') Category Index
                nav.product-directory-nav(aria-label='Product categories')
                    each category, categoryIndex in productCategories
                        a.product-directory-link(class=categoryIndex === 0 ? 'is-active' : '', href=`#${category.key}`, data-product-directory-link=category.key)
                            .product-directory-link-row
                                span.product-directory-link-index= `0${categoryIndex + 1}`
                                .product-directory-link-title
                                    span.product-directory-link-title-zh= category.titleZh
                                    span.product-directory-link-title-en= category.titleEn
                            .product-directory-link-detail
                                p.product-directory-link-copy(data-i18n=`products.category.${category.key}.description`, data-en=category.descriptionEn, data-zh=category.descriptionZh)= category.descriptionEn
                                p.product-directory-link-count
                                    span.product-directory-link-count-label(data-i18n='products.overview.summaryLabel', data-en='Product Count', data-zh='产品数量') Product Count
                                    strong= category.items.length

            .product-directory-content
                .product-category-stack
                    each category, categoryIndex in productCategories
                        article(id=category.key class=`product-category-panel ${category.themeClass}` data-product-section=category.key)
                            .product-category-panel-header
                                .product-category-panel-heading
                                    p.product-category-panel-index= `0${categoryIndex + 1}`
                                    h2.product-category-panel-title
                                        span.product-category-panel-title-zh= category.titleZh
                                        span.product-category-panel-title-en= category.titleEn
                                    p.product-category-panel-copy(data-i18n=`products.category.${category.key}.description`, data-en=category.descriptionEn, data-zh=category.descriptionZh)= category.descriptionEn
                                .product-category-panel-summary
                                    p.product-category-summary-label(data-i18n='products.overview.summaryLabel', data-en='Product Count', data-zh='产品数量') Product Count
                                    p.product-category-summary-value= category.items.length
                            .product-card-grid
                                each item in category.items
                                    a.product-card(href=item.link)
                                        .product-card-media
                                            img(src=item.image, alt=item.nameEn)
                                        .product-card-body
                                            p.product-card-series= category.titleEn
                                            h3.product-card-title
                                                span.product-card-title-zh= item.nameZh
                                                span.product-card-title-en= item.nameEn
                                            p.product-card-copy(data-i18n=`products.item.${item.key}.description`, data-en=item.descriptionEn, data-zh=item.descriptionZh)= item.descriptionEn
                                        .product-card-footer
                                            span.product-card-action(data-i18n=`products.item.${item.key}.action`, data-en=item.actionEn, data-zh=item.actionZh)= item.actionEn
                                            span.product-card-arrow &rarr;
