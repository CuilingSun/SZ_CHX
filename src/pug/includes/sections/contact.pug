section#contact.page-section
    .container
        .text-center
            h2.section-heading.text-uppercase(data-i18n='contact.heading', data-en='Contact Us', data-zh='联系我们') Contact Us
            h3.section-subheading.text-muted(data-i18n='contact.subheading', data-en='Tell us what you are building and we will get back to you shortly.', data-zh='告诉我们你想做的项目，我们会尽快与你联系。') Tell us what you are building and we will get back to you shortly.
        form#contactForm(data-sb-form-api-token='API_TOKEN')
            .row.align-items-stretch.mb-5
                .col-md-6
                    .form-group
                        input#name.form-control(
                            type='text',
                            placeholder='Your Name *',
                            data-i18n-placeholder='contact.form.name',
                            data-placeholder-en='Your Name *',
                            data-placeholder-zh='你的姓名 *',
                            data-sb-validations='required'
                        )
                        .invalid-feedback(data-sb-feedback='name:required', data-i18n='contact.form.nameRequired', data-en='A name is required.', data-zh='请输入姓名。')
                            | A name is required.
                    .form-group
                        input#email.form-control(
                            type='email',
                            placeholder='Your Email *',
                            data-i18n-placeholder='contact.form.email',
                            data-placeholder-en='Your Email *',
                            data-placeholder-zh='你的邮箱 *',
                            data-sb-validations='required,email'
                        )
                        .invalid-feedback(data-sb-feedback='email:required', data-i18n='contact.form.emailRequired', data-en='An email is required.', data-zh='请输入邮箱。')
                            | An email is required.
                        .invalid-feedback(data-sb-feedback='email:email', data-i18n='contact.form.emailInvalid', data-en='Email is not valid.', data-zh='邮箱格式不正确。')
                            | Email is not valid.
                    .form-group.mb-md-0
                        input#phone.form-control(
                            type='tel',
                            placeholder='Your Phone *',
                            data-i18n-placeholder='contact.form.phone',
                            data-placeholder-en='Your Phone *',
                            data-placeholder-zh='你的电话 *',
                            data-sb-validations='required'
                        )
                        .invalid-feedback(data-sb-feedback='phone:required', data-i18n='contact.form.phoneRequired', data-en='A phone number is required.', data-zh='请输入电话。')
                            | A phone number is required.
                .col-md-6
                    .form-group.form-group-textarea.mb-md-0
                        textarea#message.form-control(
                            placeholder='Your Message *',
                            data-i18n-placeholder='contact.form.message',
                            data-placeholder-en='Your Message *',
                            data-placeholder-zh='你的留言 *',
                            data-sb-validations='required'
                        )
                        .invalid-feedback(data-sb-feedback='message:required', data-i18n='contact.form.messageRequired', data-en='A message is required.', data-zh='请输入留言内容。')
                            | A message is required.
            #submitSuccessMessage.d-none
                .text-center.text-white.mb-3
                    .fw-bolder(data-i18n='contact.success.title', data-en='Form submission successful!', data-zh='提交成功！') Form submission successful!
                    span(data-i18n='contact.success.text', data-en='To activate this form, sign up at', data-zh='如需启用该表单，请前往以下地址注册') To activate this form, sign up at
                    br
                    a(href='https://startbootstrap.com/solution/contact-forms') https://startbootstrap.com/solution/contact-forms
            #submitErrorMessage.d-none
                .text-center.text-danger.mb-3(data-i18n='contact.error', data-en='Error sending message!', data-zh='发送失败，请稍后重试。') Error sending message!
            .text-center
                button#submitButton.btn.btn-primary.btn-xl.text-uppercase.disabled(type='submit', data-i18n='contact.button', data-en='Send Message', data-zh='发送信息') Send Message
