section#contact.page-section
    .container
        .contact-layout
            .contact-info-col
                p.contact-kicker(data-i18n='contact.kicker', data-en='Reach Us', data-zh='联系我们') Reach Us
                h2(data-i18n='contact.heading', data-en='Get in Touch', data-zh='与我们沟通') Get in Touch
                p.contact-intro(data-i18n='contact.intro', data-en='For product selection, quotations, and technical support, our team responds promptly.', data-zh='如需产品选型、报价或技术支持，我们的团队将迅速响应。') For product selection, quotations, and technical support, our team responds promptly.

                .contact-details
                    .contact-detail
                        .contact-detail-icon
                            i.fas.fa-map-marker-alt(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.address', data-en='Address', data-zh='地址') Address
                            span.contact-detail-value 深圳市宝安西乡大道221号（丽景城1栋125号）
                    .contact-detail
                        .contact-detail-icon
                            i.fas.fa-phone(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.telephone', data-en='Telephone', data-zh='电话') Telephone
                            span.contact-detail-value 0755-29566383 &nbsp;/&nbsp; 0755-29566380
                    .contact-detail
                        .contact-detail-icon
                            i.fas.fa-fax(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.fax', data-en='Fax', data-zh='传真') Fax
                            span.contact-detail-value 0755-29566381
                    .contact-detail
                        .contact-detail-icon
                            i.fas.fa-mobile-alt(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.mobile', data-en='Mobile', data-zh='手机') Mobile
                            a.contact-detail-link(href='tel:+8618925269628') +86 189 2526 9628
                    .contact-detail
                        .contact-detail-icon
                            i.fas.fa-envelope(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.email', data-en='Email', data-zh='邮箱') Email
                            a.contact-detail-link(href='mailto:szchx188@163.com') szchx188@163.com
                    .contact-detail
                        .contact-detail-icon
                            i.fas.fa-comments(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.qq', data-en='QQ', data-zh='QQ') QQ
                            span.contact-detail-value 790360920 &nbsp;·&nbsp; 785645609 &nbsp;·&nbsp; 793799080
                    .contact-detail
                        .contact-detail-icon
                            i.fab.fa-weixin(aria-hidden='true')
                        div
                            span.contact-detail-label(data-i18n='contact.info.wechat', data-en='WeChat', data-zh='微信') WeChat
                            span.contact-detail-value 18925269628

            .contact-form-col
                .contact-form-card
                    p.contact-form-kicker(data-i18n='contact.form.kicker', data-en='Send an Inquiry', data-zh='发送询盘') Send an Inquiry
                    h3(data-i18n='contact.form.title', data-en='Request a Quote or Consultation', data-zh='申请报价或技术咨询') Request a Quote or Consultation
                    form.contact-form(action='mailto:szchx188@163.com', method='post', enctype='text/plain')
                        .row.g-3
                            .col-sm-6
                                label.form-label(for='contactName', data-i18n='contact.form.name', data-en='Name', data-zh='姓名') Name
                                input#contactName.form-control(type='text', name='name', required)
                            .col-sm-6
                                label.form-label(for='contactCompany', data-i18n='contact.form.company', data-en='Company', data-zh='公司名称') Company
                                input#contactCompany.form-control(type='text', name='company')
                            .col-sm-6
                                label.form-label(for='contactPhone', data-i18n='contact.form.phone', data-en='Phone', data-zh='电话') Phone
                                input#contactPhone.form-control(type='tel', name='phone')
                            .col-sm-6
                                label.form-label(for='contactEmail', data-i18n='contact.form.email', data-en='Email', data-zh='邮箱') Email
                                input#contactEmail.form-control(type='email', name='email', required)
                            .col-12
                                label.form-label(for='contactType', data-i18n='contact.form.type', data-en='Inquiry Type', data-zh='询盘类型') Inquiry Type
                                select#contactType.form-select(name='type')
                                    option(value='product', data-i18n='contact.form.type.product', data-en='Product Inquiry', data-zh='产品询盘') Product Inquiry
                                    option(value='quote', data-i18n='contact.form.type.quote', data-en='Request a Quote', data-zh='申请报价') Request a Quote
                                    option(value='technical', data-i18n='contact.form.type.technical', data-en='Technical Support', data-zh='技术支持') Technical Support
                                    option(value='other', data-i18n='contact.form.type.other', data-en='Other', data-zh='其他') Other
                            .col-12
                                label.form-label(for='contactMessage', data-i18n='contact.form.message', data-en='Message / Requirements', data-zh='留言 / 需求说明') Message / Requirements
                                textarea#contactMessage.form-control(name='message', rows='4', placeholder='Please describe your product requirements, quantities, or any technical questions...', data-i18n-placeholder='contact.form.message.placeholder', data-placeholder-en='Please describe your product requirements, quantities, or any technical questions...', data-placeholder-zh='请描述您的产品需求、数量或技术问题……')
                        .contact-form-submit
                            button.btn.btn-primary.btn-xl(type='submit', data-i18n='contact.form.submit', data-en='Send Message', data-zh='发送消息') Send Message
