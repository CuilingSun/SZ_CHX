section.industries-page
    .container
        .industries-grid
            .industry-card
                .industry-card-image
                    img(src='assets/img/industry/机械设备.jpeg', alt='Mechanical Equipment')
                .industry-card-body
                    span.industry-kicker(data-i18n='industries.item1.kicker', data-en='Industrial Machinery', data-zh='工业机械') Industrial Machinery
                    h3(data-i18n='industries.item1.title', data-en='Mechanical Equipment', data-zh='机械设备') Mechanical Equipment
                    p.industry-desc(data-i18n='industries.item1.desc', data-en='From hydraulic cylinders to pneumatic actuators, our seals handle the demanding cycles and pressures found in industrial machinery — ensuring leak-free operation and extended service life.', data-zh='从液压缸到气动执行器，我们的密封件能够承受工业机械中高强度的循环工况与压力，确保无泄漏运行并延长使用寿命。') From hydraulic cylinders to pneumatic actuators, our seals handle the demanding cycles and pressures found in industrial machinery — ensuring leak-free operation and extended service life.
                    p.industry-products-label(data-i18n='industries.products_label', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                    .industry-tags
                        span.industry-tag(data-i18n='industries.tag.hydraulic_seals', data-en='Hydraulic Seals', data-zh='液压密封件') Hydraulic Seals
                        span.industry-tag(data-i18n='industries.tag.piston_seals', data-en='Piston Seals', data-zh='活塞密封') Piston Seals
                        span.industry-tag(data-i18n='industries.tag.rod_seals', data-en='Rod Seals', data-zh='杆密封') Rod Seals
                        span.industry-tag(data-i18n='industries.tag.wiper_seals', data-en='Wiper Seals', data-zh='防尘密封') Wiper Seals
                    a.btn.btn-outline-primary.industry-cta(href='products.html', data-i18n='industries.cta', data-en='View Related Products', data-zh='查看相关产品') View Related Products

            .industry-card
                .industry-card-image
                    img(src='assets/img/industry/汽车.png', alt='Automotive')
                .industry-card-body
                    span.industry-kicker(data-i18n='industries.item2.kicker', data-en='Vehicle Systems', data-zh='车辆系统') Vehicle Systems
                    h3(data-i18n='industries.item2.title', data-en='Automotive', data-zh='汽车') Automotive
                    p.industry-desc(data-i18n='industries.item2.desc', data-en='Our sealing solutions support automotive applications including power steering, braking systems, transmissions, and engine components — meeting the precision tolerances and durability standards required by the industry.', data-zh='我们的密封方案适用于汽车动力转向、制动系统、变速箱及发动机部件等应用，满足行业所需的精密公差与耐久性标准。') Our sealing solutions support automotive applications including power steering, braking systems, transmissions, and engine components — meeting the precision tolerances and durability standards required by the industry.
                    p.industry-products-label(data-i18n='industries.products_label', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                    .industry-tags
                        span.industry-tag(data-i18n='industries.tag.oil_seals', data-en='Oil Seals', data-zh='油封') Oil Seals
                        span.industry-tag(data-i18n='industries.tag.o_rings', data-en='O-Rings', data-zh='O形圈') O-Rings
                        span.industry-tag(data-i18n='industries.tag.shaft_seals', data-en='Shaft Seals', data-zh='轴密封') Shaft Seals
                        span.industry-tag(data-i18n='industries.tag.ptfe_seals', data-en='PTFE Seals', data-zh='PTFE密封') PTFE Seals
                    a.btn.btn-outline-primary.industry-cta(href='products.html', data-i18n='industries.cta', data-en='View Related Products', data-zh='查看相关产品') View Related Products

            .industry-card
                .industry-card-image
                    img(src='assets/img/industry/石油化工.jpg', alt='Petrochemical')
                .industry-card-body
                    span.industry-kicker(data-i18n='industries.item3.kicker', data-en='Chemical Processing', data-zh='化工流程') Chemical Processing
                    h3(data-i18n='industries.item3.title', data-en='Petrochemical', data-zh='石油化工') Petrochemical
                    p.industry-desc(data-i18n='industries.item3.desc', data-en='High-pressure, high-temperature, and chemically aggressive environments demand seals with exceptional material resistance. We supply FDA-compliant and chemically inert solutions for pumps, valves, and reactors across the petrochemical sector.', data-zh='高压、高温及强腐蚀性环境对密封件的材料耐受性提出极高要求。我们为石化行业的泵、阀门及反应器提供符合FDA标准的惰性密封解决方案。') High-pressure, high-temperature, and chemically aggressive environments demand seals with exceptional material resistance. We supply FDA-compliant and chemically inert solutions for pumps, valves, and reactors across the petrochemical sector.
                    p.industry-products-label(data-i18n='industries.products_label', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                    .industry-tags
                        span.industry-tag(data-i18n='industries.tag.viton_seals', data-en='Viton Seals', data-zh='氟橡胶密封') Viton Seals
                        span.industry-tag(data-i18n='industries.tag.high_pressure', data-en='High-Pressure Seals', data-zh='高压密封') High-Pressure Seals
                        span.industry-tag(data-i18n='industries.tag.ptfe_seals', data-en='PTFE Seals', data-zh='PTFE密封') PTFE Seals
                        span.industry-tag(data-i18n='industries.tag.gaskets', data-en='Gaskets', data-zh='垫片') Gaskets
                    a.btn.btn-outline-primary.industry-cta(href='products.html', data-i18n='industries.cta', data-en='View Related Products', data-zh='查看相关产品') View Related Products

            .industry-card
                .industry-card-image
                    img(src='assets/img/industry/电子.png', alt='Electronics')
                .industry-card-body
                    span.industry-kicker(data-i18n='industries.item4.kicker', data-en='Precision Components', data-zh='精密部件') Precision Components
                    h3(data-i18n='industries.item4.title', data-en='Electronics', data-zh='电子') Electronics
                    p.industry-desc(data-i18n='industries.item4.desc', data-en='Electronics manufacturing requires seals with tight dimensional tolerances, clean-room compatibility, and resistance to solvents used in production. Our precision-grade O-rings and gaskets support semiconductor, display, and PCB processing equipment.', data-zh='电子制造对密封件的尺寸精度、洁净室兼容性及溶剂耐受性有严格要求。我们的精密级O形圈和垫片适用于半导体、显示器及PCB加工设备。') Electronics manufacturing requires seals with tight dimensional tolerances, clean-room compatibility, and resistance to solvents used in production. Our precision-grade O-rings and gaskets support semiconductor, display, and PCB processing equipment.
                    p.industry-products-label(data-i18n='industries.products_label', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                    .industry-tags
                        span.industry-tag(data-i18n='industries.tag.o_rings', data-en='O-Rings', data-zh='O形圈') O-Rings
                        span.industry-tag(data-i18n='industries.tag.precision_seals', data-en='Precision Seals', data-zh='精密密封') Precision Seals
                        span.industry-tag(data-i18n='industries.tag.epdm_seals', data-en='EPDM Seals', data-zh='三元乙丙密封') EPDM Seals
                        span.industry-tag(data-i18n='industries.tag.gaskets', data-en='Gaskets', data-zh='垫片') Gaskets
                    a.btn.btn-outline-primary.industry-cta(href='products.html', data-i18n='industries.cta', data-en='View Related Products', data-zh='查看相关产品') View Related Products

            .industry-card
                .industry-card-image
                    img(src='assets/img/industry/工业电机.webp', alt='Electrical Appliances')
                .industry-card-body
                    span.industry-kicker(data-i18n='industries.item5.kicker', data-en='Home & Industrial Appliances', data-zh='家用与工业电器') Home & Industrial Appliances
                    h3(data-i18n='industries.item5.title', data-en='Electrical Appliances', data-zh='电器') Electrical Appliances
                    p.industry-desc(data-i18n='industries.item5.desc', data-en='Appliance manufacturers depend on reliable sealing for water pumps, compressors, and motors. We offer cost-effective, durable seals that meet the lifecycle demands of both household and commercial equipment.', data-zh='家电制造商在水泵、压缩机和电机中依赖可靠的密封性能。我们提供经济耐用的密封件，满足家用及商用设备的全生命周期要求。') Appliance manufacturers depend on reliable sealing for water pumps, compressors, and motors. We offer cost-effective, durable seals that meet the lifecycle demands of both household and commercial equipment.
                    p.industry-products-label(data-i18n='industries.products_label', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                    .industry-tags
                        span.industry-tag(data-i18n='industries.tag.oil_seals', data-en='Oil Seals', data-zh='油封') Oil Seals
                        span.industry-tag(data-i18n='industries.tag.o_rings', data-en='O-Rings', data-zh='O形圈') O-Rings
                        span.industry-tag(data-i18n='industries.tag.mechanical_seals', data-en='Mechanical Seals', data-zh='机械密封') Mechanical Seals
                        span.industry-tag(data-i18n='industries.tag.rubber_parts', data-en='Rubber Parts', data-zh='橡胶件') Rubber Parts
                    a.btn.btn-outline-primary.industry-cta(href='products.html', data-i18n='industries.cta', data-en='View Related Products', data-zh='查看相关产品') View Related Products

            .industry-card
                .industry-card-image
                    img(src='assets/img/industry/船舶.jpg', alt='Shipbuilding')
                .industry-card-body
                    span.industry-kicker(data-i18n='industries.item6.kicker', data-en='Marine Systems', data-zh='船舶系统') Marine Systems
                    h3(data-i18n='industries.item6.title', data-en='Shipbuilding & Maintenance', data-zh='船舶及维修制造') Shipbuilding & Maintenance
                    p.industry-desc(data-i18n='industries.item6.desc', data-en='Marine environments expose seals to saltwater corrosion, extreme pressures, and wide temperature ranges. Our marine-grade sealing products are used in propulsion systems, steering gear, deck equipment, and maintenance overhauls worldwide.', data-zh='船舶环境使密封件面临盐水腐蚀、极端压力和宽温度范围的挑战。我们的船用级密封产品广泛应用于推进系统、转向装置、甲板设备及全球范围内的维修大修。') Marine environments expose seals to saltwater corrosion, extreme pressures, and wide temperature ranges. Our marine-grade sealing products are used in propulsion systems, steering gear, deck equipment, and maintenance overhauls worldwide.
                    p.industry-products-label(data-i18n='industries.products_label', data-en='Recommended Products', data-zh='推荐产品') Recommended Products
                    .industry-tags
                        span.industry-tag(data-i18n='industries.tag.hydraulic_seals', data-en='Hydraulic Seals', data-zh='液压密封件') Hydraulic Seals
                        span.industry-tag(data-i18n='industries.tag.high_pressure', data-en='High-Pressure Seals', data-zh='高压密封') High-Pressure Seals
                        span.industry-tag(data-i18n='industries.tag.viton_seals', data-en='Viton Seals', data-zh='氟橡胶密封') Viton Seals
                        span.industry-tag(data-i18n='industries.tag.custom_seals', data-en='Custom Solutions', data-zh='定制方案') Custom Solutions
                    a.btn.btn-outline-primary.industry-cta(href='products.html', data-i18n='industries.cta', data-en='View Related Products', data-zh='查看相关产品') View Related Products
