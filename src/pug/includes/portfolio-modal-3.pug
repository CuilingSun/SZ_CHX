// Portfolio item 3 modal popup
#portfolioModal3.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase(data-i18n='modal3.title', data-en='Petrochemical', data-zh='石油化工') Petrochemical
                            p.item-intro.text-muted(data-i18n='modal3.intro', data-en='Materials and sealing support for aggressive media, pressure systems, and process equipment.' data-zh='适用于腐蚀介质、压力系统和流程设备的材料与密封支持。') Materials and sealing support for aggressive media, pressure systems, and process equipment.
                            img.img-fluid.d-block.mx-auto(src='assets/img/portfolio/3.jpg', alt='...')
                            p(data-i18n='modal3.text', data-en='Petrochemical environments place strict demands on chemical resistance, pressure retention, and service reliability. Our sealing solutions help process equipment maintain integrity across pipelines, pumps, valves, and related process units.' data-zh='石油化工环境对耐介质性、承压能力和使用可靠性要求极高。我们的密封方案适用于管路、泵阀以及相关流程设备，帮助系统在复杂工况下保持稳定运行。') Petrochemical environments place strict demands on chemical resistance, pressure retention, and service reliability. Our sealing solutions help process equipment maintain integrity across pipelines, pumps, valves, and related process units.
                            ul.list-inline
                                li
                                    strong(data-i18n='modal.industry', data-en='Industry:' data-zh='行业：') Industry:
                                    | Petrochemical
                                li
                                    strong(data-i18n='modal.application', data-en='Application:' data-zh='应用：') Application:
                                    span(data-i18n='modal3.category', data-en='Chemical Processing', data-zh='化工流程') Chemical Processing
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                span(data-i18n='modal.close', data-en='Close' data-zh='关闭') Close
