// Portfolio item 1 modal popup
#portfolioModal1.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase(data-i18n='modal1.title', data-en='Mechanical Equipment', data-zh='机械设备') Mechanical Equipment
                            p.item-intro.text-muted(data-i18n='modal1.intro', data-en='Sealing support for industrial machinery, transmission systems, and automated equipment.' data-zh='适用于工业机械、传动系统和自动化设备的密封配套。') Sealing support for industrial machinery, transmission systems, and automated equipment.
                            img.img-fluid.d-block.mx-auto(src='assets/img/industry/机械设备.jpeg', alt='...')
                            p(data-i18n='modal1.text', data-en='Mechanical equipment often runs under continuous loads, dust exposure, and complex motion conditions. Our sealing and rubber components help improve equipment stability, reduce leakage risk, and support long-term operation in industrial production environments.' data-zh='机械设备通常面临持续负载、粉尘环境以及复杂运动工况。我们的密封与橡胶制品可帮助设备提升运行稳定性，降低泄漏风险，并支持工业生产环境下的长期可靠运行。') Mechanical equipment often runs under continuous loads, dust exposure, and complex motion conditions. Our sealing and rubber components help improve equipment stability, reduce leakage risk, and support long-term operation in industrial production environments.
                            ul.list-inline
                                li
                                    strong(data-i18n='modal.industry', data-en='Industry:' data-zh='行业：') Industry:
                                    | Mechanical Equipment
                                li
                                    strong(data-i18n='modal.application', data-en='Application:' data-zh='应用：') Application:
                                    span(data-i18n='modal1.category', data-en='Industrial Machinery', data-zh='工业机械') Industrial Machinery
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                span(data-i18n='modal.close', data-en='Close' data-zh='关闭') Close
