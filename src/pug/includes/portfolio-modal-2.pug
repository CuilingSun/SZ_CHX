// Portfolio item 2 modal popup
#portfolioModal2.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase(data-i18n='modal2.title', data-en='Automotive', data-zh='汽车') Automotive
                            p.item-intro.text-muted(data-i18n='modal2.intro', data-en='Reliable sealing for engine systems, chassis assemblies, and vehicle durability requirements.' data-zh='服务于发动机系统、底盘总成和整车耐久性要求的密封方案。') Reliable sealing for engine systems, chassis assemblies, and vehicle durability requirements.
                            img.img-fluid.d-block.mx-auto(src='assets/img/portfolio/2.jpg', alt='...')
                            p(data-i18n='modal2.text', data-en='Automotive applications demand consistency under vibration, temperature cycling, and fluid exposure. Our products are suitable for sealing interfaces, vibration control, and component protection in both passenger and commercial vehicle systems.' data-zh='汽车应用需要在振动、温差循环和介质接触条件下保持稳定表现。我们的产品适用于乘用车与商用车系统中的密封连接、减震控制及部件防护。') Automotive applications demand consistency under vibration, temperature cycling, and fluid exposure. Our products are suitable for sealing interfaces, vibration control, and component protection in both passenger and commercial vehicle systems.
                            ul.list-inline
                                li
                                    strong(data-i18n='modal.industry', data-en='Industry:' data-zh='行业：') Industry:
                                    | Automotive
                                li
                                    strong(data-i18n='modal.application', data-en='Application:' data-zh='应用：') Application:
                                    span(data-i18n='modal2.category', data-en='Vehicle Systems', data-zh='车辆系统') Vehicle Systems
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                span(data-i18n='modal.close', data-en='Close' data-zh='关闭') Close
