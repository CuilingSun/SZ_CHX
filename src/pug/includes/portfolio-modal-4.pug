// Portfolio item 4 modal popup
#portfolioModal4.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase(data-i18n='modal4.title', data-en='Electronics', data-zh='电子') Electronics
                            p.item-intro.text-muted(data-i18n='modal4.intro', data-en='Precision sealing and protection for compact assemblies and sensitive electronic structures.' data-zh='服务于精密装配和敏感电子结构的密封与防护方案。') Precision sealing and protection for compact assemblies and sensitive electronic structures.
                            img.img-fluid.d-block.mx-auto(src='assets/img/industry/电子.png', alt='...')
                            p(data-i18n='modal4.text', data-en='Electronic products often require small-size, high-precision components with stable insulation and sealing performance. Our rubber and sealing parts can support connectors, housings, sensors, and other compact assemblies.' data-zh='电子产品通常需要小尺寸、高精度且具备稳定绝缘与密封性能的部件。我们的橡胶与密封产品可应用于连接器、外壳、传感器等精密结构。') Electronic products often require small-size, high-precision components with stable insulation and sealing performance. Our rubber and sealing parts can support connectors, housings, sensors, and other compact assemblies.
                            ul.list-inline
                                li
                                    strong(data-i18n='modal.industry', data-en='Industry:' data-zh='行业：') Industry:
                                    | Electronics
                                li
                                    strong(data-i18n='modal.application', data-en='Application:' data-zh='应用：') Application:
                                    span(data-i18n='modal4.category', data-en='Precision Components', data-zh='精密部件') Precision Components
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                span(data-i18n='modal.close', data-en='Close' data-zh='关闭') Close
