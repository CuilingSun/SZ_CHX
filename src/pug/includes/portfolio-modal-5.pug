// Portfolio item 5 modal popup
#portfolioModal5.portfolio-modal.modal.fade(tabindex='-1', role='dialog', aria-hidden='true')
    .modal-dialog
        .modal-content
            .close-modal(data-bs-dismiss='modal')
                img(src='assets/img/close-icon.svg', alt='Close modal')
            .container
                .row.justify-content-center
                    .col-lg-8
                        .modal-body
                            // Project details
                            h2.text-uppercase(data-i18n='modal5.title', data-en='Electrical Appliances', data-zh='电器') Electrical Appliances
                            p.item-intro.text-muted(data-i18n='modal5.intro', data-en='Rubber and sealing components for appliances, motors, controls, and enclosure systems.' data-zh='适用于家电、电机、控制部件和外壳系统的橡胶与密封组件。') Rubber and sealing components for appliances, motors, controls, and enclosure systems.
                            img.img-fluid.d-block.mx-auto(src='assets/img/portfolio/5.jpg', alt='...')
                            p(data-i18n='modal5.text', data-en='Electrical appliances require dependable sealing, cushioning, and insulation in compact spaces. Our products can be integrated into home appliances and industrial electrical equipment to improve assembly reliability and service life.' data-zh='电器产品通常在紧凑空间中同时要求密封、缓冲和绝缘性能。我们的产品可应用于家用电器与工业电气设备中，帮助提升装配可靠性和使用寿命。') Electrical appliances require dependable sealing, cushioning, and insulation in compact spaces. Our products can be integrated into home appliances and industrial electrical equipment to improve assembly reliability and service life.
                            ul.list-inline
                                li
                                    strong(data-i18n='modal.industry', data-en='Industry:' data-zh='行业：') Industry:
                                    | Electrical Appliances
                                li
                                    strong(data-i18n='modal.application', data-en='Application:' data-zh='应用：') Application:
                                    span(data-i18n='modal5.category', data-en='Home & Industrial Appliances', data-zh='家用与工业电器') Home & Industrial Appliances
                            button.btn.btn-primary.btn-xl.text-uppercase(data-bs-dismiss='modal', type='button')
                                i.fas.fa-xmark.me-1
                                span(data-i18n='modal.close', data-en='Close' data-zh='关闭') Close
